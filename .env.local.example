# ── Supabase ─────────────────────────────────────────────────────────────────
#
# Find these in your Supabase project:
#   Dashboard → Settings → API
#
# NEXT_PUBLIC_ prefix = safe to expose to the browser
# SUPABASE_SERVICE_ROLE_KEY = NEVER prefix with NEXT_PUBLIC_ (server-only)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Optional (future) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   ← only needed if you add client-side auth
